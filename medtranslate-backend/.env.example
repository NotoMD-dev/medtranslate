# ==========================================================
# OpenAI Configuration
# ==========================================================

# REQUIRED: API key for server-side translation
OPENAI_API_KEY=

# Default model (can still be overridden per request)
DEFAULT_MODEL=gpt-5.2

# ==========================================================
# Translation Concurrency Controls
# ==========================================================

# Maximum simultaneous OpenAI translation requests
# Increase cautiously based on rate limits
MAX_CONCURRENT_TRANSLATIONS=10

# Number of rows processed per translation chunk
# Prevents creating thousands of tasks at once
TRANSLATION_CHUNK_SIZE=200

# ==========================================================
# Metric Controls
# ==========================================================

# Whether to compute BERTScore by default
# (Can still be overridden via API toggle)
DEFAULT_COMPUTE_BERTSCORE=true

# Batch size for BERTScore (affects RAM usage)
BERTSCORE_BATCH_SIZE=64

# ==========================================================
# Job Limits & Safety
# ==========================================================

# Maximum rows allowed in a single CSV upload
# Prevents memory blowups on Render
MAX_ROWS_PER_JOB=10000

# Automatically delete job results after N seconds
# (0 disables cleanup)
JOB_TTL_SECONDS=86400

# ==========================================================
# Server
# ==========================================================

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO