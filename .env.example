# MedTranslate Environment Configuration
# Copy this file to .env.local and fill in your API keys

# OpenAI API key (for GPT-5.2 translations)
OPENAI_API_KEY=sk-...

# Anthropic API key (for Claude translations)
ANTHROPIC_API_KEY=sk-ant-...

# Default model for translations
# Options: gpt-5.2, claude-sonnet-4-20250514
DEFAULT_MODEL=gpt-5.2
