# Copy this file to .env.local and fill in the values.
#
# FastAPI backend URL — used by Next.js rewrites proxy.
# The frontend proxies /api/* requests through the Next.js server to this URL,
# which avoids CORS issues entirely.
#
# Local development:
BACKEND_URL=http://localhost:8000
#
# Production (e.g. Vercel → Render):
# BACKEND_URL=https://your-backend.onrender.com
